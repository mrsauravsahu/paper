#!/usr/bin/env bash

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

INPUT=""
PANDOC_VARS=""
VERBOSE=false
PRESERVE=false

for arg in "$@"; do
  case "$arg" in
    --continuous)
      PANDOC_VARS="$PANDOC_VARS -V continuous-pages=true"
      ;;
    --pages=yes)
      ;;
    --pages=no)
      PANDOC_VARS="$PANDOC_VARS -V no-page-numbers=true"
      ;;
    -v|--verbose)
      VERBOSE=true
      ;;
    -P|--preserve)
      PRESERVE=true
      ;;
    -*)
      echo "Unknown flag: $arg" >&2
      echo "Usage: paper <file.md> [--continuous] [--pages=yes|no] [-P] [-v]" >&2
      exit 1
      ;;
    *)
      INPUT="$arg"
      ;;
  esac
done

if [ -z "$INPUT" ]; then
  echo "Usage: paper <file.md> [--continuous] [--pages=yes|no] [-P] [-v]" >&2
  exit 1
fi

$VERBOSE && set -x

INPUT_BASENAME="$(basename "$INPUT")"
OUTPUT="${INPUT_BASENAME%.md}.pdf"
OUTPUT_PATH="$(pwd)/$OUTPUT"

echo "Generating PDF..."
docker run --rm \
  -v "$(pwd):/data" \
  -v "$SCRIPT_DIR:/paper" \
  paper:latest bash -c \
  "node /paper/pandoc-emoji-filter.js /data/$INPUT_BASENAME /data/$INPUT_BASENAME.out.md && \
   pandoc /data/$INPUT_BASENAME.out.md -o /data/$OUTPUT \
     --template=/paper/template.tex \
     --filter=/paper/node_modules/.bin/mermaid-filter \
     --filter=/paper/emoji_filter.js \
     $PANDOC_VARS && \
   rm /data/$INPUT_BASENAME.out.md"

open "$OUTPUT_PATH"

set +x


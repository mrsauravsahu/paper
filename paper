#!/usr/bin/env bash

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

INPUT=""
PANDOC_VARS=""
VERBOSE=false
PRESERVE=true

for arg in "$@"; do
  case "$arg" in
    --continuous)
      PANDOC_VARS="$PANDOC_VARS -V continuous-page=true"
      ;;
    --breaks=yes)
      PANDOC_VARS="$PANDOC_VARS -V section-breaks=true"
      ;;
    --breaks=no)
      ;;
    --title=yes)
      PANDOC_VARS="$PANDOC_VARS -V show-title=true"
      ;;
    --title=no)
      ;;
    --pages=yes)
      PANDOC_VARS="$PANDOC_VARS -V show-page-numbers=true"
      ;;
    --pages=no)
      ;;
    -v|--verbose)
      VERBOSE=true
      ;;
    -P|--preserve)
      PRESERVE=true
      ;;
    -*)
      echo "Unknown flag: $arg" >&2
      echo "Usage: paper <file.md> [--continuous] [--breaks=yes|no] [--title=yes|no] [--pages=yes|no] [-P] [-v]" >&2
      exit 1
      ;;
    *)
      INPUT="$arg"
      ;;
  esac
done

if [ -z "$INPUT" ]; then
  echo "Usage: paper <file.md> [--continuous] [--breaks=yes|no] [--title=yes|no] [--pages=yes|no] [-P] [-v]" >&2
  exit 1
fi

$VERBOSE && set -x

INPUT_DIR="$(cd "$(dirname "$INPUT")" && pwd)"
INPUT_BASENAME="$(basename "$INPUT")"
OUTPUT_BASENAME="${INPUT_BASENAME%.md}.pdf"
OUTPUT_PATH="$INPUT_DIR/$OUTPUT_BASENAME"

echo "Generating PDF..."
docker run --rm \
  -v "$INPUT_DIR:/data" \
  -e MERMAID_FILTER_FORMAT=pdf \
  paper:latest bash -c \
  "node /paper/src/pandoc-emoji-filter.js /data/$INPUT_BASENAME /data/$INPUT_BASENAME.out.md && \
   pandoc /data/$INPUT_BASENAME.out.md -o /data/$OUTPUT_BASENAME \
     --template=/paper/config/template.tex \
     --filter=/paper/node_modules/.bin/mermaid-filter \
     --filter=/paper/src/emoji-filter.js \
     $PANDOC_VARS && \
   rm /data/$INPUT_BASENAME.out.md"

open "$OUTPUT_PATH"

set +x


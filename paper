#!/usr/bin/env bash

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

INPUT=""
OUTPUT=""
PANDOC_VARS=""
VERBOSE=false
NO_OPEN=false

USAGE="Usage: paper <file.md> -o <output.pdf> | -n [--continuous] [--breaks=yes|no] [--title=yes|no] [--pages=yes|no] [-v]"

while [[ $# -gt 0 ]]; do
  arg="$1"
  case "$arg" in
    --continuous)
      PANDOC_VARS="$PANDOC_VARS -V continuous-page=true"
      ;;
    --breaks=yes)
      PANDOC_VARS="$PANDOC_VARS -V section-breaks=true"
      ;;
    --breaks=no)
      ;;
    --title=yes)
      PANDOC_VARS="$PANDOC_VARS -V show-title=true"
      ;;
    --title=no)
      ;;
    --pages=yes)
      PANDOC_VARS="$PANDOC_VARS -V show-page-numbers=true"
      ;;
    --pages=no)
      ;;
    -v|--verbose)
      VERBOSE=true
      ;;
    -n|--no-open)
      NO_OPEN=true
      ;;
    -o|--output)
      OUTPUT="$2"
      shift
      ;;
    --output=*)
      OUTPUT="${arg#--output=}"
      ;;
    -*)
      echo "Unknown flag: $arg" >&2
      echo "$USAGE" >&2
      exit 1
      ;;
    *)
      INPUT="$arg"
      ;;
  esac
  shift
done

if [ -z "$INPUT" ]; then
  echo "$USAGE" >&2
  exit 1
fi

if [ -z "$OUTPUT" ] && ! $NO_OPEN; then
  echo "Specify -o <output.pdf> to save the PDF, or -n to check generation only." >&2
  echo "$USAGE" >&2
  exit 1
fi

$VERBOSE && set -x

INPUT_DIR="$(cd "$(dirname "$INPUT")" && pwd)"
INPUT_BASENAME="$(basename "$INPUT")"
OUTPUT_BASENAME="${INPUT_BASENAME%.md}.pdf"

if [ -n "$OUTPUT" ]; then
  OUTPUT_PATH="$(cd "$(dirname "$OUTPUT")" && pwd)/$(basename "$OUTPUT")"
  OUTPUT_DIR="$(dirname "$OUTPUT_PATH")"
  DOCKER_OUTPUT_MOUNT="-v $OUTPUT_DIR:/output"
  PANDOC_OUTPUT="/output/$(basename "$OUTPUT_PATH")"
else
  DOCKER_OUTPUT_MOUNT=""
  PANDOC_OUTPUT="/tmp/$OUTPUT_BASENAME"
fi

echo "Generating PDF..."
docker run --rm \
  -v "$INPUT_DIR:/input" \
  $DOCKER_OUTPUT_MOUNT \
  -e MERMAID_FILTER_FORMAT=pdf \
  paper:latest bash -c \
  "node /paper/src/pandoc-emoji-filter.js /input/$INPUT_BASENAME /input/$INPUT_BASENAME.out.md && \
   pandoc /input/$INPUT_BASENAME.out.md -o $PANDOC_OUTPUT \
     --template=/paper/config/template.tex \
     --filter=/paper/node_modules/.bin/mermaid-filter \
     --filter=/paper/src/emoji-filter.js \
     $PANDOC_VARS && \
   rm /input/$INPUT_BASENAME.out.md"

if [ -n "$OUTPUT" ] && ! $NO_OPEN; then
  echo "$OUTPUT_PATH"
  open "$OUTPUT_PATH"
fi

set +x
